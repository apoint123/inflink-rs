{
	"name": "inflink-rs-workspace",
	"private": true,
	"version": "3.2.11",
	"license": "GPL-3.0-only",
	"packageManager": "bun@1.3.12",
	"engines": {
		"node": ">=20.0.0",
		"bun": ">=1.3.5"
	},
	"workspaces": [
		"packages/frontend"
	],
	"scripts": {
		"build": "cd packages/frontend && vite build",
		"dev": "cd packages/frontend && vite build --watch --mode development",
		"build:frontend": "cd packages/frontend && vite build --mode frontend-only",
		"lint": "bun biome check . --error-on-warnings",
		"format": "bun biome format . --write",
		"typecheck": "bun tsgo -b",
		"prepare": "husky",
		"cs:add": "bun changeset add",
		"cs:version": "bun changeset version && bun ./scripts/sync-versions.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@changesets/cli": "^2.30.0",
		"@types/bun": "^1.3.12",
		"@typescript/native-preview": "=7.0.0-dev.20260607.1",
		"husky": "^9.1.7",
		"vite": "^8.0.8",
		"vite-plugin-css-injected-by-js": "^5.0.0"
	}
}
